# Copiá todo esto en tu .env y ponele los valores que vos necesites 

# PostgreSQL (contenedor db)
POSTGRES_USER=vacaciones
POSTGRES_PASSWORD=vacaciones
POSTGRES_DB=vacaciones

# Puerto expuesto en el host (tu manager de DB, psql local)
POSTGRES_PUBLISHED_PORT=5432

# Host/puerto vistos desde el servicio bot (red interna de Docker)
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Regla de negocio: solicitudes con hasta N días hábiles se auto-aprueban
AUTO_APPROVE_THRESHOLD=5

# Opcional — solo si corrés el bot fuera de Docker (python -m bot.main):
# DATABASE_URL=postgresql://vacaciones:vacaciones@localhost:5432/vacaciones # asegurate de reemplazar los valores con los tuyos si usas esta opción
